                    const minutesValues = [1, 5, 10, 15, 20, 25, 30, 35, 40, 45, 50, 55, 59];
                    const value = minutesValues[i] || null;
                    
                    if (value) {
                      return (
                        <TouchableOpacity 
                          key={value} 
                          style={{ 
