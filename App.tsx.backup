            fontWeight: 'bold',
            color: theme.text,
            marginBottom: 8,
          }}>
            Connected Device
          </Text>
          <Text style={{
            fontSize: 14,
            color: theme.textSecondary,
            marginBottom: 4,
          }}>
            Name: {device.name || 'Unknown'}
          </Text>
          <Text style={{
            fontSize: 12,
            color: theme.textSecondary,
            fontFamily: 'monospace',
          }}>
            ID: {device.id}
          </Text>
        </View>
      )}

      {/* Error Display */}
      {error && (
        <View style={{
          backgroundColor: '#ffebee',
          marginHorizontal: 20,
          marginBottom: 20,
          padding: 16,
          borderRadius: 12,
          borderLeftWidth: 4,
          borderLeftColor: '#f44336',
        }}>
          <Text style={{
            fontSize: 14,
            color: '#c62828',
            fontWeight: 'bold',
            marginBottom: 4,
          }}>
            Error
          </Text>
          <Text style={{
            fontSize: 12,
            color: '#c62828',
          }}>
            {error}
          </Text>
        </View>
      )}

      {/* Control Buttons */}
      <View style={{
        padding: 20,
        gap: 16,
      }}>
        {/* Get Logs Button */}
        <TouchableOpacity
          style={{
            backgroundColor: isLogging ? '#ff9800' : '#4caf50',
            paddingVertical: 16,
            paddingHorizontal: 24,
            borderRadius: 12,
            alignItems: 'center',
            elevation: 3,
            shadowColor: '#000',
            shadowOffset: { width: 0, height: 2 },
            shadowOpacity: 0.2,
            shadowRadius: 4,
          }}
          onPress={startLogging}
          disabled={isLogging || isConnecting || !device}
        >
          <View style={{ flexDirection: 'row', alignItems: 'center' }}>
            <Icon 
              name={isLogging ? "pause" : isConnecting ? "loading" : "play"} 
              size={20} 
              color="#fff" 
              style={{ marginRight: 8 }}
            />
            <Text style={{
              color: '#fff',
              fontSize: 16,
              fontWeight: 'bold',
            }}>
              {isConnecting ? 'Connecting...' : isLogging ? 'Logging Active...' : 'Get Logs'}
            </Text>
          </View>
        </TouchableOpacity>

        {/* Stop Logs Button */}
        <TouchableOpacity
          style={{
            backgroundColor: '#f44336',
            paddingVertical: 16,
            paddingHorizontal: 24,
            borderRadius: 12,
            alignItems: 'center',
            elevation: 3,
            shadowColor: '#000',
            shadowOffset: { width: 0, height: 2 },
            shadowOpacity: 0.2,
            shadowRadius: 4,
          }}
          onPress={stopLogging}
          disabled={!isLogging}
        >
          <View style={{ flexDirection: 'row', alignItems: 'center' }}>
            <Icon 
              name="stop" 
              size={20} 
              color="#fff" 
              style={{ marginRight: 8 }}
            />
            <Text style={{
              color: '#fff',
              fontSize: 16,
              fontWeight: 'bold',
            }}>
              Stop Logs
            </Text>
          </View>
        </TouchableOpacity>

        {/* Clear Logs Button */}
        <TouchableOpacity
          style={{
            backgroundColor: '#9e9e9e',
            paddingVertical: 16,
            paddingHorizontal: 24,
            borderRadius: 12,
            alignItems: 'center',
            elevation: 3,
            shadowColor: '#000',
            shadowOffset: { width: 0, height: 2 },
            shadowOpacity: 0.2,
            shadowRadius: 4,
          }}
          onPress={clearLogs}
        >
          <View style={{ flexDirection: 'row', alignItems: 'center' }}>
            <Icon 
              name="delete" 
              size={20} 
              color="#fff" 
              style={{ marginRight: 8 }}
            />
            <Text style={{
              color: '#fff',
              fontSize: 16,
              fontWeight: 'bold',
            }}>
              Clear Logs
            </Text>
          </View>
        </TouchableOpacity>

        {/* Debug Device Button */}
        <TouchableOpacity
          style={{
            backgroundColor: '#ff9800',
            paddingVertical: 12,
            paddingHorizontal: 24,
            borderRadius: 12,
            alignItems: 'center',
            elevation: 3,
            shadowColor: '#000',
            shadowOffset: { width: 0, height: 2 },
            shadowOpacity: 0.2,
            shadowRadius: 4,
          }}
          onPress={async () => {
            if (!device) {
              setError('No device selected');
              return;
            }
            
            try {
              setError('');
              const deviceToUse = await connectToDevice();
              if (!deviceToUse) return;
              
              const services = await deviceToUse.services();
              let debugInfo = `Device: ${device.name} (${device.id})\n`;
              debugInfo += `Connected: ${deviceToUse ? 'Yes' : 'No'}\n\n`;
              debugInfo += `Services (${services.length}):\n`;
              
              for (const service of services) {
                debugInfo += `- ${service.uuid}\n`;
                const characteristics = await deviceToUse.characteristicsForService(service.uuid);
                debugInfo += `  Characteristics (${characteristics.length}):\n`;
                
                for (const char of characteristics) {
                  const props = [];
                  if (char.isReadable) props.push('Read');
                  if (char.isWritableWithResponse) props.push('Write');
                  if (char.isWritableWithoutResponse) props.push('WriteNoResponse');
                  if (char.isNotifiable) props.push('Notify');
                  if (char.isIndicatable) props.push('Indicate');
                  
                  debugInfo += `    - ${char.uuid} (${props.join(', ')})\n`;
                }
              }
              
              console.log('Device Debug Info:', debugInfo);
              setLogs(prev => [...prev, `[${new Date().toLocaleTimeString()}] DEBUG INFO:\n${debugInfo}`]);
              
            } catch (err: any) {
              setError(`Debug failed: ${err.message}`);
            }
          }}
        >
          <View style={{ flexDirection: 'row', alignItems: 'center' }}>
            <Icon 
              name="bug" 
              size={20} 
              color="#fff" 
              style={{ marginRight: 8 }}
            />
            <Text style={{
              color: '#fff',
              fontSize: 16,
              fontWeight: 'bold',
            }}>
              Debug Device
            </Text>
          </View>
        </TouchableOpacity>

