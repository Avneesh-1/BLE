        backgroundColor={theme.isDark ? '#000000' : '#00bcd4'} 
        barStyle={theme.isDark ? "light-content" : "dark-content"} 
        translucent={true}
      />
      
      {/* Header */}
      <View style={{
        backgroundColor: theme.isDark ? '#1a1a1a' : '#00bcd4',
        paddingHorizontal: 20,
        paddingVertical: 16,
