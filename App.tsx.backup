        }
      }, index * 1000); // Send one log every second
    });
  };
  */

  useEffect(() => {
    return () => {
      if (logInterval) {
        clearInterval(logInterval);
      }
      if (connectedDevice) {
        connectedDevice.cancelConnection().catch(err => {
          console.log('Cleanup disconnect error:', err);
        });
      }
    };
  }, [logInterval, connectedDevice]);

  return (
    <View style={{ 
      flex: 1, 
      backgroundColor: theme.isDark ? '#121212' : '#f5f5f5',
      paddingTop: getHeaderHeight(),
    }}>
      <StatusBar 
        backgroundColor={theme.isDark ? '#000000' : '#00bcd4'} 
        barStyle={theme.isDark ? "light-content" : "dark-content"} 
        translucent={true}
      />
      
      {/* Header */}
      <View style={{
        backgroundColor: theme.isDark ? '#1a1a1a' : '#00bcd4',
        paddingHorizontal: 20,
        paddingVertical: 16,
        elevation: 4,
        shadowColor: '#000',
        shadowOffset: { width: 0, height: 2 },
        shadowOpacity: 0.1,
        shadowRadius: 4,
      }}>
        <View style={{ flexDirection: 'row', alignItems: 'center' }}>
          <TouchableOpacity
            onPress={() => navigation.goBack()}
            style={{
              width: 40,
              height: 40,
              borderRadius: 20,
              backgroundColor: 'rgba(255,255,255,0.2)',
              alignItems: 'center',
              justifyContent: 'center',
              marginRight: 16,
            }}
          >
            <Icon name="arrow-left" size={20} color={theme.isDark ? '#fff' : '#fff'} />
          </TouchableOpacity>
          <Text style={{
            fontSize: 24,
            fontWeight: 'bold',
            color: theme.isDark ? '#fff' : '#fff',
            flex: 1,
          }}>
            Live Logs
          </Text>
        </View>
      </View>

      {/* Device Info */}
      {device && (
        <View style={{
          backgroundColor: theme.isDark ? '#2a2a2a' : '#e3f2fd',
          marginHorizontal: 20,
          marginBottom: 20,
          padding: 16,
          borderRadius: 12,
          borderLeftWidth: 4,
          borderLeftColor: '#00bcd4',
        }}>
          <Text style={{
