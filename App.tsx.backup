        shadowColor: '#000',
        shadowOffset: { width: 0, height: 2 },
        shadowOpacity: 0.1,
        shadowRadius: 4,
      }}>
        <View style={{ flexDirection: 'row', alignItems: 'center' }}>
          <TouchableOpacity
            onPress={() => navigation.goBack()}
            style={{
              width: 40,
              height: 40,
              borderRadius: 20,
              backgroundColor: 'rgba(255,255,255,0.2)',
              alignItems: 'center',
              justifyContent: 'center',
              marginRight: 16,
            }}
          >
            <Icon name="arrow-left" size={20} color={theme.isDark ? '#fff' : '#fff'} />
          </TouchableOpacity>
          <Text style={{
            fontSize: 24,
            fontWeight: 'bold',
            color: theme.isDark ? '#fff' : '#fff',
            flex: 1,
          }}>
            Live Logs
          </Text>
        </View>
      </View>

      {/* Placeholder Content */}
      <View style={{
        flex: 1,
        justifyContent: 'center',
        alignItems: 'center',
        paddingHorizontal: 20,
      }}>
        <Icon 
          name="file-document-outline" 
          size={64} 
          color={theme.textSecondary} 
        />
        <Text style={{
          fontSize: 18,
          color: theme.textSecondary,
          marginTop: 16,
          textAlign: 'center',
        }}>
          Logs functionality removed
        </Text>
        <Text style={{
          fontSize: 14,
          color: theme.textSecondary,
          marginTop: 8,
          textAlign: 'center',
        }}>
          Ready for reimplementation
        </Text>
      </View>
    </View>
  );
}
      setLogs(prev => [...prev, `[${new Date().toLocaleTimeString()}] 🔗 Setting up connection state...`]);
      setIsConnecting(true);
      setError('');
      
      console.log('Attempting to connect to device:', device.id);
      setLogs(prev => [...prev, `[${new Date().toLocaleTimeString()}] 🔗 Starting connection to device: ${device.id}`]);
      
      // First, try to cancel any existing connection
      try {
        await manager.cancelDeviceConnection(device.id);
        await new Promise(resolve => setTimeout(resolve, 1000)); // Wait before reconnecting
      } catch (err) {
        console.log('Cancel connection error (expected):', err);
      }
      
      // Connect with timeout, retry, and pairing support
      let connectedDevice = null;
      let retryCount = 0;
      const maxRetries = 3;
      
      setLogs(prev => [...prev, `[${new Date().toLocaleTimeString()}] 🔗 Starting connection loop (max ${maxRetries} attempts)`]);
      
      while (retryCount < maxRetries && !connectedDevice) {
        try {
          console.log(`Connection attempt ${retryCount + 1}/${maxRetries}`);
          setLogs(prev => [...prev, `[${new Date().toLocaleTimeString()}] 🔗 Connection attempt ${retryCount + 1}/${maxRetries}`]);
          
          // Try to connect with pairing support
          connectedDevice = await manager.connectToDevice(device.id, { 
            timeout: 15000, // 15 second timeout for pairing
            requestMTU: 512, // Request larger MTU for better data transfer
            autoConnect: true // Enable auto-connect for better pairing
          });
          
          console.log('Device connected, checking pairing status...');
          setLogs(prev => [...prev, `[${new Date().toLocaleTimeString()}] ✅ Device connected, checking pairing status...`]);
          
          // Check if device is paired by trying to read a basic characteristic
          try {
          await connectedDevice.discoverAllServicesAndCharacteristics();
            console.log('Services discovered, checking pairing...');
            
            // Try to read a basic characteristic to verify pairing
            const testChar = await connectedDevice.readCharacteristicForService(
              '00001800-0000-1000-8000-00805f9b34fb', // Generic Access service
              '00002a00-0000-1000-8000-00805f9b34fb'  // Device Name characteristic
            );
            console.log('Device is properly paired and accessible');
            
          } catch (pairingErr: any) {
            console.log('Pairing issue detected:', pairingErr.message);
            
            // Try to request pairing
            try {
              console.log('Requesting device pairing...');
              await connectedDevice.requestConnectionPriority('high');
              
              // Wait a bit for pairing to complete
              await new Promise(resolve => setTimeout(resolve, 2000));
              
              // Try reading again
              await connectedDevice.readCharacteristicForService(
                '00001800-0000-1000-8000-00805f9b34fb',
                '00002a00-0000-1000-8000-00805f9b34fb'
              );
              console.log('Pairing successful after request');
              
            } catch (pairingRequestErr: any) {
              console.log('Pairing request failed:', pairingRequestErr.message);
              throw new Error('Device requires manual pairing in Bluetooth settings');
            }
          }
          
          setConnectedDevice(connectedDevice);
          setIsConnecting(false);
          setLogs(prev => [...prev, `[${new Date().toLocaleTimeString()}] ✅ Connection successful!`]);
          return connectedDevice;
          
        } catch (err: any) {
          const errorMessage = err && err.message ? err.message : 'Unknown error';
          console.log(`Connection attempt ${retryCount + 1} failed:`, err);
          setLogs(prev => [...prev, `[${new Date().toLocaleTimeString()}] ❌ Connection attempt ${retryCount + 1} failed: ${errorMessage}`]);
          retryCount++;
          
          if (retryCount < maxRetries) {
            console.log('Retrying connection...');
            setLogs(prev => [...prev, `[${new Date().toLocaleTimeString()}] 🔄 Retrying connection...`]);
            await new Promise(resolve => setTimeout(resolve, 2000)); // Wait 2 seconds before retry
          } else {
            setLogs(prev => [...prev, `[${new Date().toLocaleTimeString()}] ❌ All connection attempts failed`]);
          }
        }
      }
      
      // If we get here, all retries failed

          }
        }
        
      } catch (discoverErr: any) {
        const errorMessage = discoverErr && discoverErr.message ? discoverErr.message : 'Unknown error';
        setLogs(prev => [...prev, `[${new Date().toLocaleTimeString()}] ⚠️  Service discovery failed: ${errorMessage}`]);
      }
      
      // Try multiple service UUIDs that might contain logs
      const possibleServices = [
        '00000180-0000-1000-8000-00805f9b34fb', // Custom service
        '0000fff0-0000-1000-8000-00805f9b34fb', // Alternative service
        '0000ffe0-0000-1000-8000-00805f9b34fb', // Another alternative
        '0000ff00-0000-1000-8000-00805f9b34fb', // Generic service
        '0000fe00-0000-1000-8000-00805f9b34fb', // Another generic
      ];
      
      const possibleReadChars = [
        '0000fff1-0000-1000-8000-00805f9b34fb', // Original read char
        '0000fff2-0000-1000-8000-00805f9b34fb', // Alternative read char
        '0000ffe1-0000-1000-8000-00805f9b34fb', // Another read char
        '0000ff01-0000-1000-8000-00805f9b34fb', // Generic read char
        '0000fe01-0000-1000-8000-00805f9b34fb', // Another generic
      ];
      
      // Use only F1 (Write characteristic) for sending commands
      const writeCharacteristic = '0000fff1-0000-1000-8000-00805f9b34fb'; // F1 - Write
      const notifyCharacteristic = '0000fff3-0000-1000-8000-00805f9b34fb'; // F3 - Notify
      const serviceUUID = '00000180-0000-1000-8000-00805f9b34fb'; // Custom service
      
      let logsFound = false;
      
            // Check if this is a pairing issue
      setLogs(prev => [...prev, `[${new Date().toLocaleTimeString()}] 🔐 Checking device pairing status...`]);
      
      try {
        // Try to read a simple characteristic to test pairing
        const testChar = await device.readCharacteristicForService('00001800-0000-1000-8000-00805f9b34fb', '00002a00-0000-1000-8000-00805f9b34fb');
        setLogs(prev => [...prev, `[${new Date().toLocaleTimeString()}] ✅ Device is properly paired - can read basic characteristics`]);
      } catch (pairingErr: any) {
        const errorMessage = pairingErr && pairingErr.message ? pairingErr.message : 'Unknown error';
        setLogs(prev => [...prev, `[${new Date().toLocaleTimeString()}] ❌ PAIRING ISSUE DETECTED: ${errorMessage}`]);
        setLogs(prev => [...prev, `[${new Date().toLocaleTimeString()}] 💡 SOLUTION: Go to your phone's Bluetooth settings`]);
        setLogs(prev => [...prev, `[${new Date().toLocaleTimeString()}] 💡 Find device "14:2B:2F:C1:E5:E6" and pair/connect it`]);
        setLogs(prev => [...prev, `[${new Date().toLocaleTimeString()}] 💡 Then try this app again`]);
        return; // Exit early if pairing is the issue
      }
      
      setLogs(prev => [...prev, `[${new Date().toLocaleTimeString()}] 📖 Device is paired, following Write → Notify flow...`]);
      
      // Step 1: Send command to F1 (Write characteristic)
      setLogs(prev => [...prev, `[${new Date().toLocaleTimeString()}] 📤 Step 1: Sending command to F1 (Write characteristic)...`]);
      
      try {
        setLogs(prev => [...prev, `[${new Date().toLocaleTimeString()}] 🔧 Writing to service: ${serviceUUID.substring(0, 8)}..., char: ${writeCharacteristic.substring(0, 8)}...`]);
        
        // Send the {$send_logs} command to F1
        const command = '{$send_logs}';
        setLogs(prev => [...prev, `[${new Date().toLocaleTimeString()}] 📝 Sending command: "${command}" to F1`]);
        
        // Try different formats for the command
        const commandFormats = [
          command, // Original string
          Buffer.from(command).toString('base64'), // Base64 encoded
          Buffer.from(command + '\n').toString('base64'), // With newline
        ];
        
        let commandSent = false;
        for (const format of commandFormats) {
          try {
            setLogs(prev => [...prev, `[${new Date().toLocaleTimeString()}] 🔧 Trying format: "${format.substring(0, 20)}${format.length > 20 ? '...' : ''}"`]);
            
            // Try without response first
            try {
              await device.writeCharacteristicWithoutResponseForService(serviceUUID, writeCharacteristic, format);
              setLogs(prev => [...prev, `[${new Date().toLocaleTimeString()}] ✅ Command sent to F1 successfully (without response)`]);
              commandSent = true;
              break;
            } catch (writeWithoutResponseErr: any) {
              setLogs(prev => [...prev, `[${new Date().toLocaleTimeString()}] ⚠️ Write without response failed, trying with response`]);
              await device.writeCharacteristicWithResponseForService(serviceUUID, writeCharacteristic, format);
              setLogs(prev => [...prev, `[${new Date().toLocaleTimeString()}] ✅ Command sent to F1 successfully (with response)`]);
              commandSent = true;
              break;
            }
            
          } catch (formatErr: any) {
            const errorMessage = formatErr && formatErr.message ? formatErr.message : 'Unknown error';
            setLogs(prev => [...prev, `[${new Date().toLocaleTimeString()}] ❌ Failed format: ${errorMessage}`]);
            }
        }
        
        if (!commandSent) {
          setLogs(prev => [...prev, `[${new Date().toLocaleTimeString()}] ❌ Failed to send command to F1`]);
          return;
          }
          
        // Wait for device to process the command
        setLogs(prev => [...prev, `[${new Date().toLocaleTimeString()}] ⏳ Waiting for device to process command...`]);
          await new Promise(resolve => setTimeout(resolve, 2000));
          
        } catch (writeErr: any) {
        const errorMessage = writeErr && writeErr.message ? writeErr.message : 'Unknown error';
        setLogs(prev => [...prev, `[${new Date().toLocaleTimeString()}] ❌ Failed to write to F1: ${errorMessage}`]);
        return;
      }
      
             // Step 2: Set up monitoring on F3 (Notify characteristic)
       setLogs(prev => [...prev, `[${new Date().toLocaleTimeString()}] 📡 Step 2: Setting up monitoring on F3 (Notify characteristic)...`]);
        
        try {
          await device.monitorCharacteristicForService(
           serviceUUID,
           notifyCharacteristic,
            (error, characteristic) => {
              if (error) {
               const errorMessage = error && error.message ? error.message : 'Unknown error';
               setLogs(prev => [...prev, `[${new Date().toLocaleTimeString()}] ❌ Notification error: ${errorMessage}`]);
                return;
              }
              
              if (characteristic && characteristic.value) {
               const newValue = Buffer.from(characteristic.value, 'base64').toString('utf8');
               setLogs(prev => [...prev, `[${new Date().toLocaleTimeString()}] 📡 NOTIFICATION RECEIVED FROM F3: "${newValue}"`]);
               
               if (newValue && newValue.trim() !== '') {
                 // Check if this looks like our log format
                 if (newValue.includes('D:') && newValue.includes('T:') && newValue.includes('Server:')) {
                   const logData = parseLogData(newValue);
                   if (logData) {
                     const formattedLog = formatLogForDisplay(logData);
                const timestamp = new Date().toLocaleTimeString();
                     setLogs(prev => [...prev, `[${timestamp}] 📊 REAL SENSOR DATA FROM F3:\n${formattedLog}`]);
                   } else {
                     const timestamp = new Date().toLocaleTimeString();
                     setLogs(prev => [...prev, `[${timestamp}] 📋 RAW LOG FROM F3: ${newValue}`]);
                   }
                 } else {
                   const timestamp = new Date().toLocaleTimeString();
                   setLogs(prev => [...prev, `[${timestamp}] 📋 DEVICE DATA FROM F3: ${newValue}`]);
                 }
               }
              }
            }
          );
          
         setLogs(prev => [...prev, `[${new Date().toLocaleTimeString()}] ✅ Monitoring set up on F3 successfully`]);
         
       } catch (monitorErr: any) {
         const errorMessage = monitorErr && monitorErr.message ? monitorErr.message : 'Unknown error';
         setLogs(prev => [...prev, `[${new Date().toLocaleTimeString()}] ❌ Failed to set up monitoring on F3: ${errorMessage}`]);
        }
        
        setLogs(prev => [...prev, `[${new Date().toLocaleTimeString()}] ✅ Write → Notify flow completed successfully`]);
        setLogs(prev => [...prev, `[${new Date().toLocaleTimeString()}] 📡 Waiting for sensor data from F3 (Notify characteristic)...`]);
          
      // If no logs found, try to read from any readable characteristic
      if (!logsFound) {
        setLogs(prev => [...prev, `[${new Date().toLocaleTimeString()}] 🔍 No logs found in expected characteristics, trying all readable characteristics...`]);
        
          try {
            const services = await device.services();
            let foundReadable = false;
            
            for (const service of services) {
              const characteristics = await device.characteristicsForService(service.uuid);
              
              for (const char of characteristics) {
                if (char.isReadable) {
                  try {
                  setLogs(prev => [...prev, `[${new Date().toLocaleTimeString()}] 🔍 Trying readable: ${service.uuid.substring(0, 8)}... - ${char.uuid.substring(0, 8)}...`]);
                  
                    const readChar = await device.readCharacteristicForService(service.uuid, char.uuid);
                    const newValue = Buffer.from(readChar.value, 'base64').toString('utf8');
                    
                  setLogs(prev => [...prev, `[${new Date().toLocaleTimeString()}] ✅ Read from characteristic: "${newValue.substring(0, 50)}${newValue.length > 50 ? '...' : ''}"`]);
                    
                  if (newValue && newValue.trim() !== '') {
                    const timestamp = new Date().toLocaleTimeString();
                    setLogs(prev => [...prev, `[${timestamp}] 📋 READABLE DATA: ${newValue}`]);
                    foundReadable = true;
                  }
                  
                  } catch (charReadErr: any) {
                    const errorMessage = charReadErr && charReadErr.message ? charReadErr.message : 'Unknown error';
                    setLogs(prev => [...prev, `[${new Date().toLocaleTimeString()}] ❌ Failed to read from ${char.uuid.substring(0, 8)}...: ${errorMessage}`]);
                  }
                }
              }
              if (foundReadable) break;
            }
            
            if (!foundReadable) {
            const timestamp = new Date().toLocaleTimeString();
            setLogs(prev => [...prev, `[${timestamp}] ⚠️  No readable data found from device`]);
          }
          
        } catch (fallbackErr: any) {
          const errorMessage = fallbackErr && fallbackErr.message ? fallbackErr.message : 'Unknown error';
          setLogs(prev => [...prev, `[${new Date().toLocaleTimeString()}] ❌ All read attempts failed: ${errorMessage}`]);
        }
      }
      
      // Set up monitoring for real-time log notifications
      setLogs(prev => [...prev, `[${new Date().toLocaleTimeString()}] 🔄 Setting up real-time monitoring...`]);
      
      try {
        const services = await device.services();
        
        for (const service of services) {
          const characteristics = await device.characteristicsForService(service.uuid);
          
          for (const char of characteristics) {
            if (char.isNotifiable) {
              try {
                await device.monitorCharacteristicForService(
                  service.uuid,
                  char.uuid,
                  (error, characteristic) => {
                    if (error) {
                      const errorMessage = error && error.message ? error.message : 'Unknown error';
                      setLogs(prev => [...prev, `[${new Date().toLocaleTimeString()}] ❌ Notification error: ${errorMessage}`]);
            return;
                    }
                    
                    if (characteristic && characteristic.value) {
                      const decodedValue = Buffer.from(characteristic.value, 'base64').toString('utf8');
                      const timestamp = new Date().toLocaleTimeString();
                      
                      // Check if this is our log format
                      if (decodedValue.includes('D:') && decodedValue.includes('T:') && decodedValue.includes('Server:')) {
                        const logData = parseLogData(decodedValue);
                        if (logData) {
                          const formattedLog = formatLogForDisplay(logData);
                          setLogs(prev => [...prev, `[${timestamp}] 🔄 REAL-TIME LOG:\n${formattedLog}`]);
                        } else {
                          setLogs(prev => [...prev, `[${timestamp}] 🔄 REAL-TIME RAW: ${decodedValue}`]);
                        }
                      } else {
                        setLogs(prev => [...prev, `[${timestamp}] 🔄 NOTIFICATION: ${decodedValue}`]);
                      }
                    }
                  }
                );
                
                setLogs(prev => [...prev, `[${new Date().toLocaleTimeString()}] ✅ Monitoring set up for service: ${service.uuid.substring(0, 8)}..., char: ${char.uuid.substring(0, 8)}...`]);
                
              } catch (monitorErr: any) {
                const errorMessage = monitorErr && monitorErr.message ? monitorErr.message : 'Unknown error';
                setLogs(prev => [...prev, `[${new Date().toLocaleTimeString()}] ❌ Failed to monitor characteristic: ${errorMessage}`]);
              }
            }
          }
        }
        
      } catch (monitorSetupErr: any) {
        const errorMessage = monitorSetupErr && monitorSetupErr.message ? monitorSetupErr.message : 'Unknown error';
        setLogs(prev => [...prev, `[${new Date().toLocaleTimeString()}] ❌ Failed to set up monitoring: ${errorMessage}`]);
      }
      
      // Set up periodic reading as fallback
      setLogs(prev => [...prev, `[${new Date().toLocaleTimeString()}] 🔄 Setting up periodic reading as fallback...`]);
      
      const periodicReadInterval = setInterval(async () => {
        try {
          for (const serviceUUID of possibleServices) {
            for (const readCharUUID of possibleReadChars) {
              try {
                const readChar = await device.readCharacteristicForService(serviceUUID, readCharUUID);
                const newValue = Buffer.from(readChar.value, 'base64').toString('utf8');
                
                if (newValue && newValue.trim() !== '' && newValue !== 'BLE-Server') {
                  const timestamp = new Date().toLocaleTimeString();
                  
                  // Check if this looks like our log format
                  if (newValue.includes('D:') && newValue.includes('T:') && newValue.includes('Server:')) {
                    const logData = parseLogData(newValue);
                    if (logData) {
                      const formattedLog = formatLogForDisplay(logData);
                      setLogs(prev => [...prev, `[${timestamp}] 🔄 PERIODIC SENSOR DATA:\n${formattedLog}`]);
                    } else {
                      setLogs(prev => [...prev, `[${timestamp}] 🔄 PERIODIC RAW LOG: ${newValue}`]);
                    }
                  } else {
                    setLogs(prev => [...prev, `[${timestamp}] 🔄 PERIODIC DEVICE DATA: ${newValue}`]);
                  }
                }
              } catch (readErr: any) {
                // Silent fail for periodic reads
              }
            }
          }
        } catch (periodicErr: any) {
          // Silent fail for periodic reads
        }
      }, 2000); // Read every 2 seconds
      
      // Store the interval for cleanup
      setLogs(prev => [...prev, `[${new Date().toLocaleTimeString()}] ✅ Periodic reading set up (every 2 seconds)`]);
      
    } catch (err: any) {
      const timestamp = new Date().toLocaleTimeString();
      setLogs(prev => [...prev, `[${timestamp}] ❌ BLE Communication Error: ${err.message}`]);
      throw err;
    }
  };

  const startLogging = async () => {
    if (!device) {
      setError('No device selected');
      return;
    }

    setIsLogging(true);
    setError('');
    
    try {
      setLogs(prev => [...prev, `[${new Date().toLocaleTimeString()}] 🔍 FETCHING REAL LOGS FROM DEVICE...`]);
      
      // Use the existing connected device instead of trying to reconnect
      let deviceToUse = device;
      
      setLogs(prev => [...prev, `[${new Date().toLocaleTimeString()}] 🔗 Using existing device connection: ${device.id}`]);
      
      // Always try to connect to ensure we have a fresh connection
      setLogs(prev => [...prev, `[${new Date().toLocaleTimeString()}] 🔗 Attempting to connect to device...`]);
      try {
        deviceToUse = await manager.connectToDevice(device.id, { timeout: 10000 });
        setLogs(prev => [...prev, `[${new Date().toLocaleTimeString()}] ✅ Device connected successfully`]);
      } catch (connectErr: any) {
        const errorMessage = connectErr && connectErr.message ? connectErr.message : 'Unknown error';
        setLogs(prev => [...prev, `[${new Date().toLocaleTimeString()}] ❌ CONNECTION FAILED: ${errorMessage}`]);
          setIsLogging(false);
        setError(`Connection failed: ${errorMessage}`);
          return;
      }

      console.log('Device connected, proceeding with log command...');
      setLogs(prev => [...prev, `[${new Date().toLocaleTimeString()}] ✅ Connected to device, attempting to read logs...`]);

      // Send the initial command to get logs
      try {
        await sendLogsCommand(deviceToUse);
      } catch (err) {
        console.log('Initial command failed, trying alternative approach:', err);
        
        // Try a simpler approach - just add a log entry to show we're trying
        const timestamp = new Date().toLocaleTimeString();
        setLogs(prev => [...prev, `[${timestamp}] ⚠️ Command failed, but continuing with monitoring...`]);
        
        // Continue with monitoring setup even if command fails
      }

            // Set up monitoring for log responses using the specific notify characteristic
      let monitoringSet = false;
      
      try {
        // Use the specific notify characteristic we found
        const customServiceUUID = '00000180-0000-1000-8000-00805f9b34fb';
        const notifyCharUUID = '0000fff3-0000-1000-8000-00805f9b34fb';
        
        console.log('Setting up monitoring for notify characteristic:', notifyCharUUID);
        
        await deviceToUse.monitorCharacteristicForService(
          customServiceUUID,
          notifyCharUUID,
          (error, characteristic) => {
            if (error) {
              console.log('Monitoring error:', error);
              return;
            }
            
            if (characteristic && characteristic.value) {
              const decodedValue = Buffer.from(characteristic.value, 'base64').toString();
              const timestamp = new Date().toLocaleTimeString();
              const newLog = `[${timestamp}] NOTIFY LOG: ${decodedValue}`;
              setLogs(prev => [...prev, newLog]);
              console.log('Received notify log data:', decodedValue);
            }
          }
        );
        
        monitoringSet = true;
        console.log('Monitoring set up successfully for custom service notify characteristic');
        
      } catch (err: any) {
        console.log('Failed to set up monitoring for specific characteristic, trying all notifiable:', err);
        
        // Fallback to monitoring all notifiable characteristics
        try {
          const services = await deviceToUse.services();
          
          for (const service of services) {
            const characteristics = await deviceToUse.characteristicsForService(service.uuid);
            
            for (const char of characteristics) {
              if (char.isNotifiable) {
                try {
                  await deviceToUse.monitorCharacteristicForService(
                    service.uuid,
                    char.uuid,
                    (error, characteristic) => {
                      if (error) {
                        console.log('Monitoring error:', error);
                        return;
                      }
                      
                      if (characteristic && characteristic.value) {
                        const decodedValue = Buffer.from(characteristic.value, 'base64').toString();
                        const timestamp = new Date().toLocaleTimeString();
                        const newLog = `[${timestamp}] NOTIFY LOG: ${decodedValue}`;
                        setLogs(prev => [...prev, newLog]);
                      }
                    }
                  );
                  monitoringSet = true;
                  console.log('Monitoring set up for service:', service.uuid, 'characteristic:', char.uuid);
                } catch (err: any) {
                  console.log('Failed to monitor characteristic:', err);
                }
              }
            }
          }
        } catch (discoverErr: any) {
          console.log('Service discovery failed, using polling only:', discoverErr);
        }
      }

      if (!monitoringSet) {
        console.log('No notifiable characteristics found, using polling only');
      }

      // Set up periodic command sending
      const interval = setInterval(async () => {
        try {
          if (deviceToUse) {
            console.log('Sending periodic logs command...');
            await sendLogsCommand(deviceToUse);
          } else {
            console.log('Device not available, stopping interval');
            clearInterval(interval);
            setIsLogging(false);
            setError('Device not available');
          }
        } catch (err) {
          console.log('Periodic command error:', err);
          setError(`Command error: ${err.message}`);
        }
      }, 5000); // Send command every 5 seconds
      
      setLogInterval(interval);
      
    } catch (err: any) {
      console.log('Start logging error:', err);
      setError(`Failed to start logging: ${err.message}`);
      setIsLogging(false);
    }
  };

  const stopLogging = async () => {
    setIsLogging(false);
    if (logInterval) {
      clearInterval(logInterval);
      setLogInterval(null);
    }
    
    // Disconnect from device
    if (connectedDevice) {
      try {
        await connectedDevice.cancelConnection();
        setConnectedDevice(null);
          } catch (err: any) {
      console.log('Disconnect error:', err);
    }
    }
  };

  const clearLogs = () => {
    setLogs([]);
  };

  // Simulate receiving logs from device (for testing) - Hidden for Production
  /*
  const simulateDeviceLogs = () => {
